{
  "name": "oh-my-usage",
  "version": "0.1.0",
  "description": "A local-first OpenTUI usage dashboard for Codex, Claude Code, and opencode subscription workflows.",
  "type": "module",
  "bin": {
    "oh-my-usage": "dist/cli.js",
    "omu": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/cli.ts --target=bun --outdir=dist --packages=external && bun ./scripts/fix-bin.ts",
    "dev": "bun ./src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepack": "bun run build && bun test && npm run typecheck"
  },
  "keywords": [
    "codex",
    "claude-code",
    "opencode",
    "usage",
    "tui",
    "opentui",
    "bun"
  ],
  "author": "Jasper",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasperdevs/oh-my-usage.git"
  },
  "bugs": {
    "url": "https://github.com/jasperdevs/oh-my-usage/issues"
  },
  "homepage": "https://github.com/jasperdevs/oh-my-usage#readme",
  "dependencies": {
    "@opentui/core": "^0.2.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
